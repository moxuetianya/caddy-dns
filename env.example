# 复制此文件为 .env 并填入配置
# cp env.example .env

# Cloudflare API Token (Zone:DNS:Edit 权限)
CLOUDFLARE_API_TOKEN={{CLOUDFLARE_API_TOKEN}}

# wg-easy 配置
WG_HOST={{WG_HOST}}
WG_PASSWORD_HASH={{WG_PASSWORD_HASH}}

# wg-easy v14+ 使用 bcrypt 哈希，不能使用明文密码
# install.sh 会自动生成，手动生成方法:
#   docker run --rm ghcr.io/wg-easy/wg-easy wgpw YOUR_PASSWORD
